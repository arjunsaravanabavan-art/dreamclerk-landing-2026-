{
  "buildCommand": "cd app && npm install --no-audit --no-fund --loglevel=error && npm run build",
  "outputDirectory": "app/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/#/blog/why-we-built-dreamclerk", "destination": "/blog/why-we-built-dreamclerk", "permanent": true },
    { "source": "/#/blog/inside-our-bias-audit", "destination": "/blog/inside-our-bias-audit", "permanent": true },
    { "source": "/#/blog/coding-interview-with-no-experience", "destination": "/blog/coding-interview-with-no-experience", "permanent": true },
    { "source": "/#/blog/in-browser-ide-explained", "destination": "/blog/in-browser-ide-explained", "permanent": true },
    { "source": "/#/blog/shipping-code-vs-knowing-code", "destination": "/blog/shipping-code-vs-knowing-code", "permanent": true },
    { "source": "/#/blog", "destination": "/blog", "permanent": true },
    { "source": "/#/how", "destination": "/how", "permanent": true },
    { "source": "/#/workspace", "destination": "/workspace", "permanent": true },
    { "source": "/#/tracks", "destination": "/tracks", "permanent": true },
    { "source": "/#/companies", "destination": "/companies", "permanent": true },
    { "source": "/#/faq", "destination": "/faq", "permanent": true },
    { "source": "/#/about", "destination": "/about", "permanent": true },
    { "source": "/#/privacy", "destination": "/privacy", "permanent": true },
    { "source": "/#/terms", "destination": "/terms", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, no-cache, no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
