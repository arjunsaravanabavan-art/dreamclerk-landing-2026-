# Supabase project URL — find in Project Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon public key — safe to commit, RLS protects writes
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Email of the user that may access /#/admin. Must exist in
# Supabase → Authentication → Users before signing in.
VITE_ADMIN_EMAIL=admin@yourdomain.com
